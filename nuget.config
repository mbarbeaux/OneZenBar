<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Private feed hosting the closed-source OneZenBar.Core package. -->
    <add key="github" value="https://nuget.pkg.github.com/mbarbeaux/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <!-- Credentials for the GitHub Packages feed. The password is read from the GH_PACKAGES_PAT
         environment variable (NuGet expands %VAR%): a fine-grained PAT with read:packages. CI sets
         it from the GH_PACKAGES_PAT secret before restore; locally, export it before building
         the widget. The default GITHUB_TOKEN cannot read another repo's packages, hence the PAT. -->
    <github>
      <add key="Username" value="mbarbeaux" />
      <add key="ClearTextPassword" value="%GH_PACKAGES_PAT%" />
    </github>
  </packageSourceCredentials>
</configuration>
